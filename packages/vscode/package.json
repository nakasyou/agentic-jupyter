{
  "name": "agentic-jupyter-vscode-host",
  "displayName": "Agentic Jupyter Host",
  "version": "1.0.0",
  "type": "module",
  "publisher": "nakasyou",
  "engines": {
    "vscode": "^1.99.0"
  },
  "license": "MIT",
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nakasyou/agentic-jupyter.git"
  },
  "activationEvents": [
    "onCommand:agenticJupyter.startHost",
    "onCommand:agenticJupyter.stopHost",
    "onCommand:agenticJupyter.copyConnectionInfo"
  ],
  "extensionDependencies": [
    "ms-toolsai.jupyter"
  ],
  "main": "./dist/extension.mjs",
  "files": [
    "dist/**",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -b ../cli/tsconfig.json && tsdown --config ./tsdown.config.ts",
    "vscode:prepublish": "npm run build",
    "package": "bunx @vscode/vsce package --no-dependencies",
    "publish": "bunx @vscode/vsce publish --no-dependencies"
  },
  "contributes": {
    "commands": [
      {
        "command": "agenticJupyter.startHost",
        "title": "Agentic Jupyter: Start Host"
      },
      {
        "command": "agenticJupyter.stopHost",
        "title": "Agentic Jupyter: Stop Host"
      },
      {
        "command": "agenticJupyter.copyConnectionInfo",
        "title": "Agentic Jupyter: Copy Connection Info"
      }
    ],
    "configuration": {
      "title": "Agentic Jupyter",
      "properties": {
        "agenticJupyter.host.enableAutoStart": {
          "type": "boolean",
          "default": false
        },
        "agenticJupyter.host.port": {
          "type": "number",
          "default": 8765
        },
        "agenticJupyter.host.logLevel": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info"
        }
      }
    }
  },
  "devDependencies": {
    "@vscode/jupyter-extension": "^1.1.1",
    "@vscode/vsce": "^3.7.1"
    ,
    "agentic-jupyter": "workspace:*",
    "ws": "^8.18.3"
  }
}
